---
interface Props {
    title?: string;
    subtitle?: string;
    href: string;
}

const {href, title} = Astro.props;
const page = href.substring(href.lastIndexOf("/") + 1, href.length);
const api = `https://en.wikipedia.org/api/rest_v1/page/summary/${page}`;
const res  = await fetch(api);
const data = await res.json();
const src = data.thumbnail.source as string;
const alt = data.title as string;

---
<a href={href} target="_blank" class="wikipedia-link">
    <img src={src} alt={alt}>
    <div class="titles">
        <h2>{data.title}</h2>
        <h3>{title}</h3>
    </div>
</a>

<style>
a.wikipedia-link {
    aspect-ratio: 1;
    overflow: hidden;
    display: grid;
    text-decoration: none;
    transition: ease-in-out 0.15s;
    border-radius: 1rem 0rem 1rem 0rem;
    width: 10rem;
    &:hover {
        transform: scale(1.05);
        & > img {
            transform: scale(1.1);
            transition: ease-in-out 0.2s;
            z-index: -1;
        }
    }
    & > * {
        grid-column: 1; grid-row: 1;
    }
    & > img {
        width: 100%;
        
    }
    & > div.titles {
        color: var(--rgb-text);
        
        & > h2 {
            font-weight: 600;
            font-family: Audiowide;
            text-shadow: none;
            background-color: var(--rgb-bg);
        }
        & > h3 {
            font-weight: 400;

        }
    }
}
</style>