---
interface Props {
  title: string;
  blurb: string;
  imgSrc: string;
  buttonTexts: string[];
  buttonEffects: (string|null)[],
}
const { title, blurb, imgSrc, buttonTexts, buttonEffects } = Astro.props;
---
<div class="os-style">
    <div class="window window-style">
        <div class="title">
            <h1>{title}</h1>
            <div class="x-button button-style disabled" role="button">
                <img src="/assets/img/icons/x.svg" alt="">
            </div>
        </div>
        <div class="content">
            <img src={imgSrc} alt="error icon">
            <div class="blurb"> 
                {blurb}
            <div>
        </div>
        <div class="buttons">
            {buttonTexts.map((buttonText, i) => 
                <button class="button-style" onclick={buttonEffects[i]}>
                    {buttonText}
                </button>
            )}
        </div>
    </div>
</div>
<style>
    
    .os-style {
        --rgb-os-bg: #e3e3e3;
        --rgb-os-bg-highlight: #ffffff;
        --rgb-os-bg-shadow: #747575;
        --rgb-os-accent: #7500f3;
        --rgb-os-text-color: #000000;
        --rgb-os-text-off-color: #ffffff;

        --os-border-width: 0.2rem;
        --os-font-family: "Times New Roman";
        color: var(--rgb-os-text-color);
        font-family: var(--os-font-family);
        & .window-style {
            background-color: var(--rgb-os-bg);
            border: var(--rgb-os-bg-highlight) var(--os-border-width) inset;
        }
        & .button-style {
            background-color: var(--rgb-os-bg);
            border:  var(--os-border-width) var(--rgb-os-bg-highlight) outset;
            &.disabled {
                background-color: var(--rgb-os-bg);
                border:  var(--os-border-width) var(--rgb-os-bg-highlight) inset;

                cursor: not-allowed;
        
            }
        }
        & div.window { 
            padding: 0.25rem;

            & div.title {
                background-color: var(--rgb-os-accent);
                display: flex;
                align-items: center;
                min-width: 20rem;  
                padding: 0 0.25rem;
                white-space: nowrap;
                & h1 {
                    all: unset;
                    display: block;
                    position: static;
                    padding: 0.25rem;
                    font-size: 1rem;
                    font-family: var(--os-font-family);
                    text-shadow: none;
                    font-weight: 100;
                    color: var(--rgb-os-text-off-color);
                }  
                & .x-button {
                    user-select: none;
                    margin-left: auto;
                    width: 0.75rem; 
                    height: 0.75rem;
                    aspect-ratio: 1;
                    display:flex; align-items: center; justify-content: center;
                    & img {
                        width: 1rem;
                    }
                }
            }
            & div.content {
                padding: 0.5rem 0.5rem;
                display: flex; 
                justify-content: center; align-items: center; gap: 0.5rem;
                & img {
                    width: 5rem;
                    height: 5rem;
               }
               & div.blurb {
                    max-width: 20rem;
                    font-size: 0.75rem
               }

            }
            & div.buttons {
                padding: 0.5rem 0.5rem;
                display: flex; 
                justify-content: center; align-items: center; gap: 0.5rem;
                & > button {
                    border-radius: 0;
                    width: 5rem;
                    padding: 0.25rem;
                    text-align: center;
                }
            }
            
        }
        
    }
</style>